{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "languageVersion": "2.0",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.38.33.27573",
      "templateHash": "15432187271006054473"
    },
    "name": "Azure Container Registries (ACR)",
    "description": "Construct for using an Azure Container Registries with private endpoint",
    "owner": "Gullapalli-R"
  },
  "definitions": {
    "LockType": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "nullable": true,
          "metadata": {
            "description": "Optional. Specify the name of lock."
          }
        },
        "kind": {
          "type": "string",
          "allowedValues": [
            "CanNotDelete",
            "None",
            "ReadOnly"
          ],
          "nullable": true,
          "metadata": {
            "description": "Optional. Specify the type of lock."
          }
        }
      }
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "The Geo-location where the resource lives."
      }
    },
    "name": {
      "type": "string",
      "minLength": 5,
      "maxLength": 50,
      "metadata": {
        "description": "Name of the resource."
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Gets or sets a list of key value pairs that describe the resource. These tags can be used for viewing and grouping this resource (across resource groups). A maximum of 15 tags can be provided for a resource. Each tag must have a key with a length no greater than 128 characters and a value with a length no greater than 256 characters."
      }
    },
    "skuName": {
      "type": "string",
      "defaultValue": "Premium",
      "allowedValues": [
        "Basic",
        "Premium",
        "Standard"
      ],
      "metadata": {
        "description": "The name of the SKU, Tier of Azure container registry."
      }
    },
    "adminUserEnabled": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Enable admin user that have push / pull permission to the registry."
      }
    },
    "quarantinePolicyStatusEnabled": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "The value that indicates whether the quarantine policy is enabled or not."
      }
    },
    "retentionPolicyStatusEnabled": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "The value that indicates whether the retention policy is enabled or not. Default is disabled."
      }
    },
    "retentionPolicyDays": {
      "type": "int",
      "defaultValue": 7,
      "minValue": 1,
      "maxValue": 365,
      "metadata": {
        "description": "The number of days to retain an untagged manifest after which it gets purged."
      }
    },
    "exportPolicyStatusEnabled": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "The value that indicates whether the export policy is enabled or not. Default is disabled."
      }
    },
    "softDeletePolicyStatusEnabled": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Soft Delete policy status. Default is disabled."
      }
    },
    "softDeletePolicyDays": {
      "type": "int",
      "defaultValue": 7,
      "minValue": 1,
      "maxValue": 90,
      "metadata": {
        "description": "The number of days after which a soft-deleted item is permanently deleted."
      }
    },
    "trustedServicesBypassEnabled": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Whether to allow trusted Azure services to access a network restricted registry."
      }
    },
    "zoneRedundancyEnabled": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Whether or not zone redundancy is enabled for this container registry. Default is disabled."
      }
    },
    "anonymousPullEnabled": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Enables registry-wide pull from unauthenticated clients."
      }
    },
    "subnetId": {
      "type": "string",
      "metadata": {
        "description": "The ID of the subnet from which the private IP will be allocated."
      }
    },
    "lock": {
      "$ref": "#/definitions/LockType",
      "nullable": true,
      "metadata": {
        "description": "Lock configuration for the service."
      }
    }
  },
  "variables": {
    "groupId": "registry"
  },
  "resources": {
    "registry::scope_admin": {
      "type": "Microsoft.ContainerRegistry/registries/scopeMaps",
      "apiVersion": "2023-06-01-preview",
      "name": "[format('{0}/{1}', parameters('name'), '_repositories_admin')]",
      "properties": {
        "description": "Can perform all read, write and delete operations on the registry",
        "actions": [
          "repositories/*/metadata/read",
          "repositories/*/metadata/write",
          "repositories/*/content/read",
          "repositories/*/content/write",
          "repositories/*/content/delete"
        ]
      },
      "dependsOn": [
        "registry"
      ]
    },
    "registry::scope_pull": {
      "type": "Microsoft.ContainerRegistry/registries/scopeMaps",
      "apiVersion": "2023-06-01-preview",
      "name": "[format('{0}/{1}', parameters('name'), '_repositories_pull')]",
      "properties": {
        "description": "Can pull any repository of the registry",
        "actions": [
          "repositories/*/content/read"
        ]
      },
      "dependsOn": [
        "registry"
      ]
    },
    "registry::scope_push": {
      "type": "Microsoft.ContainerRegistry/registries/scopeMaps",
      "apiVersion": "2023-06-01-preview",
      "name": "[format('{0}/{1}', parameters('name'), '_repositories_push')]",
      "properties": {
        "description": "Can push to any repository of the registry",
        "actions": [
          "repositories/*/content/read",
          "repositories/*/content/write"
        ]
      },
      "dependsOn": [
        "registry"
      ]
    },
    "registry": {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-06-01-preview",
      "name": "[parameters('name')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "[parameters('skuName')]"
      },
      "properties": {
        "adminUserEnabled": "[parameters('adminUserEnabled')]",
        "networkRuleSet": {
          "defaultAction": "Deny",
          "ipRules": []
        },
        "policies": {
          "quarantinePolicy": {
            "status": "[if(parameters('quarantinePolicyStatusEnabled'), 'enabled', 'disabled')]"
          },
          "trustPolicy": {
            "type": "Notary",
            "status": "disabled"
          },
          "retentionPolicy": {
            "days": "[parameters('retentionPolicyDays')]",
            "status": "[if(parameters('retentionPolicyStatusEnabled'), 'enabled', 'disabled')]"
          },
          "exportPolicy": {
            "status": "[if(parameters('exportPolicyStatusEnabled'), 'enabled', 'disabled')]"
          },
          "azureADAuthenticationAsArmPolicy": {
            "status": "enabled"
          },
          "softDeletePolicy": {
            "retentionDays": "[parameters('softDeletePolicyDays')]",
            "status": "[if(parameters('softDeletePolicyStatusEnabled'), 'enabled', 'disabled')]"
          }
        },
        "encryption": {
          "status": "disabled"
        },
        "dataEndpointEnabled": false,
        "publicNetworkAccess": "Disabled",
        "networkRuleBypassOptions": "[if(parameters('trustedServicesBypassEnabled'), 'AzureServices', 'None')]",
        "zoneRedundancy": "[if(parameters('zoneRedundancyEnabled'), 'Enabled', 'Disabled')]",
        "anonymousPullEnabled": "[parameters('anonymousPullEnabled')]"
      }
    },
    "registry_lock": {
      "condition": "[and(not(empty(coalesce(parameters('lock'), createObject()))), not(equals(tryGet(parameters('lock'), 'kind'), 'None')))]",
      "type": "Microsoft.Authorization/locks",
      "apiVersion": "2020-05-01",
      "scope": "[format('Microsoft.ContainerRegistry/registries/{0}', parameters('name'))]",
      "name": "[coalesce(tryGet(parameters('lock'), 'name'), format('lock-{0}', parameters('name')))]",
      "properties": {
        "level": "[coalesce(tryGet(parameters('lock'), 'kind'), '')]",
        "notes": "[if(equals(tryGet(parameters('lock'), 'kind'), 'CanNotDelete'), 'Cannot delete resource or child resources.', 'Cannot delete or modify the resource or child resources.')]"
      },
      "dependsOn": [
        "registry"
      ]
    },
    "privateEndpoint": {
      "condition": "[not(empty(parameters('subnetId')))]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[format('{0}-PE', deployment().name)]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "endpointGroupId": {
            "value": "[variables('groupId')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "name": {
            "value": "[format('{0}-{1}-PE', parameters('name'), variables('groupId'))]"
          },
          "serviceId": {
            "value": "[resourceId('Microsoft.ContainerRegistry/registries', parameters('name'))]"
          },
          "subnetId": {
            "value": "[parameters('subnetId')]"
          },
          "tags": {
            "value": "[parameters('tags')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.23.1.45101",
              "templateHash": "6916458071693187831"
            },
            "name": "Private Endpoint",
            "description": "Private Endpoint used for accessing private resources on internal networks",
            "owner": "bh-garo-yeriazarian"
          },
          "parameters": {
            "name": {
              "type": "string",
              "minLength": 2,
              "maxLength": 64,
              "metadata": {
                "description": "The resource name."
              }
            },
            "location": {
              "type": "string",
              "metadata": {
                "description": "The Geo-location where the resource lives."
              }
            },
            "subnetId": {
              "type": "string",
              "metadata": {
                "description": "The ID of the subnet from which the private IP will be allocated."
              }
            },
            "serviceId": {
              "type": "string",
              "metadata": {
                "description": "The resource id of private link service (the service being linked privately)."
              }
            },
            "tags": {
              "type": "object",
              "defaultValue": {},
              "metadata": {
                "description": "Gets or sets a list of key value pairs that describe the resource. These tags can be used for viewing and grouping this resource (across resource groups). A maximum of 15 tags can be provided for a resource. Each tag must have a key with a length no greater than 128 characters and a value with a length no greater than 256 characters."
              }
            },
            "endpointGroupId": {
              "type": "string",
              "allowedValues": [
                "account",
                "amlworkspace",
                "API",
                "application gateway",
                "AzureBackup",
                "azuremonitor",
                "AzureSiteRecovery",
                "batchAccount",
                "blob",
                "blob_secondary",
                "browser_authentication",
                "Cassandra",
                "cluster",
                "configurationStores",
                "coordinator",
                "databricks_ui_api",
                "dataFactory",
                "Dev",
                "dfs",
                "dfs_secondary",
                "domain",
                "DSCAndHybridWorker",
                "empty",
                "eventHub",
                "fhir",
                "file",
                "File Sync Service",
                "file_secondary",
                "Gremlin",
                "hosting environment",
                "HSM",
                "IoTApps",
                "iotDps",
                "iotHub",
                "keydelivery",
                "liveevent",
                "managed disk",
                "management",
                "mariadbServer",
                "MongoDB",
                "mysqlServer",
                "namespace",
                "nodeManagement",
                "portal",
                "postgresqlServer",
                "Power BI",
                "project",
                "queue",
                "queue_secondary",
                "redisCache",
                "redisEnterprise",
                "registry",
                "ResourceManagement",
                "searchService",
                "signalr",
                "sites",
                "SQL",
                "SqlOnDemand",
                "sqlServer",
                "staticSites",
                "streamingendpoint",
                "Table",
                "table",
                "table_secondary",
                "topic",
                "vault",
                "web",
                "web_secondary",
                "Webhook",
                "webpubsub"
              ],
              "metadata": {
                "description": "The ID of the group obtained from the remote resource that this private endpoint should connect to (https://learn.microsoft.com/en-us/azure/private-link/private-endpoint-overview)."
              }
            },
            "requiresManualApproval": {
              "type": "bool",
              "defaultValue": false,
              "metadata": {
                "description": "Whether or not manual approval for a Private Endpoint connection is required."
              }
            },
            "manualApprovalRequestMessage": {
              "type": "string",
              "defaultValue": "",
              "maxLength": 140,
              "metadata": {
                "description": "Message to pass on when requesting manual endpoint approval workflow."
              }
            }
          },
          "variables": {
            "privateLinkServiceConnection": {
              "name": "[parameters('name')]",
              "properties": {
                "privateLinkServiceId": "[parameters('serviceId')]",
                "groupIds": [
                  "[parameters('endpointGroupId')]"
                ],
                "requestMessage": "[if(parameters('requiresManualApproval'), parameters('manualApprovalRequestMessage'), null())]"
              }
            }
          },
          "resources": [
            {
              "type": "Microsoft.Network/privateEndpoints",
              "apiVersion": "2023-05-01",
              "name": "[parameters('name')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "properties": {
                "subnet": {
                  "id": "[parameters('subnetId')]"
                },
                "manualPrivateLinkServiceConnections": "[if(parameters('requiresManualApproval'), createArray(variables('privateLinkServiceConnection')), createArray())]",
                "privateLinkServiceConnections": "[if(parameters('requiresManualApproval'), createArray(), createArray(variables('privateLinkServiceConnection')))]",
                "customNetworkInterfaceName": "[format('{0}-NIC', parameters('name'))]"
              }
            }
          ],
          "outputs": {
            "id": {
              "type": "string",
              "metadata": {
                "description": "ID of the resource."
              },
              "value": "[resourceId('Microsoft.Network/privateEndpoints', parameters('name'))]"
            },
            "name": {
              "type": "string",
              "metadata": {
                "description": "Name of the resource."
              },
              "value": "[parameters('name')]"
            }
          }
        }
      },
      "dependsOn": [
        "registry"
      ]
    }
  },
  "outputs": {
    "id": {
      "type": "string",
      "metadata": {
        "description": "Identifier for the resource."
      },
      "value": "[resourceId('Microsoft.ContainerRegistry/registries', parameters('name'))]"
    },
    "name": {
      "type": "string",
      "metadata": {
        "description": "Name of the resource."
      },
      "value": "[parameters('name')]"
    }
  }
}