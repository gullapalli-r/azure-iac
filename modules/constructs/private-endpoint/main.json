        "managedEnvironments"
      ],
      "metadata": {
        "description": "The ID of the group obtained from the remote resource that this private endpoint should connect to (https://learn.microsoft.com/en-us/azure/private-link/private-endpoint-overview)."
      }
    },
    "requiresManualApproval": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Whether or not manual approval for a Private Endpoint connection is required."
      }
    },
    "manualApprovalRequestMessage": {
      "type": "string",
      "defaultValue": "",
      "maxLength": 140,
      "metadata": {
        "description": "Message to pass on when requesting manual endpoint approval workflow."
      }
    }
  },
  "variables": {
    "privateLinkServiceConnection": {
      "name": "[parameters('name')]",
      "properties": {
        "privateLinkServiceId": "[parameters('serviceId')]",
        "groupIds": [
          "[parameters('endpointGroupId')]"
        ],
        "requestMessage": "[if(parameters('requiresManualApproval'), parameters('manualApprovalRequestMessage'), null())]"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Network/privateEndpoints",
      "apiVersion": "2023-11-01",
      "name": "[parameters('name')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "subnet": {
          "id": "[parameters('subnetId')]"
        },
        "manualPrivateLinkServiceConnections": "[if(parameters('requiresManualApproval'), createArray(variables('privateLinkServiceConnection')), createArray())]",
        "privateLinkServiceConnections": "[if(parameters('requiresManualApproval'), createArray(), createArray(variables('privateLinkServiceConnection')))]",
        "customNetworkInterfaceName": "[format('{0}-NIC', parameters('name'))]"
      }
    }
  ],
  "outputs": {
    "id": {
      "type": "string",
      "metadata": {
        "description": "ID of the resource."
      },
      "value": "[resourceId('Microsoft.Network/privateEndpoints', parameters('name'))]"
    },
    "name": {
      "type": "string",
      "metadata": {
        "description": "Name of the resource."
      },
      "value": "[parameters('name')]"
    }
  }
